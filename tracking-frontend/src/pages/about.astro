---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="About Us | Quickship Direct">
  <Nav />

  <main class="pt-24 pb-32">
    <!-- Hero -->
    <section class="container mx-auto px-6 max-w-5xl mb-24">
      <h1 class="text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none mb-8">
        Rebuilding<br/><span class="text-[#FFD600]">Delivery.</span>
      </h1>
      <p class="text-xl md:text-2xl font-medium text-gray-500 max-w-2xl leading-relaxed">
        We believe that receiving a package should feel as magical as buying it. We're Quickship Direct, and we're bringing transparency back to the last mile.
      </p>
    </section>

    <!-- Brand Story -->
    <section class="bg-black text-white py-24 mb-24 relative overflow-hidden">
      <div class="container mx-auto px-6 max-w-5xl relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-sm font-black uppercase tracking-widest text-[#FFD600] mb-4">Our Brand Story</h2>
            <h3 class="text-4xl font-black uppercase tracking-tighter mb-8">From Logistics to Logic.</h3>
            <div class="space-y-6 text-gray-400 font-medium leading-relaxed">
              <p>
                For decades, shipping was built for businesses. Consumers were treated as endpoints—just a barcode on a box. You never knew when your package was arriving, you couldn't talk to your driver, and "Out for Delivery" meant waiting around all day.
              </p>
              <p>
                We started Quickship Direct to flip the model. We built our entire infrastructure around the person waiting by the door. 
              </p>
              <p>
                By combining a fully-electric fleet with consumer-first tracking software, we've eliminated the anxiety of the last mile. 
              </p>
            </div>
          </div>
          <div class="relative h-[500px]">
             <img src="/images/happy_unboxing.png" alt="Happy Unboxing" class="absolute inset-0 w-full h-full object-cover border-8 border-[#FFD600] mix-blend-luminosity hover:mix-blend-normal transition-all duration-700" />
          </div>
        </div>
      </div>
    </section>

    <!-- Mission & Vision -->
    <section id="mission" class="container mx-auto px-6 max-w-5xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="border-4 border-black p-12 bg-white hover:bg-[#FFD600] transition-colors duration-500 group">
          <div class="w-16 h-16 bg-black text-white flex items-center justify-center font-black text-2xl mb-8 group-hover:bg-white group-hover:text-black transition-colors">
            M
          </div>
          <h2 class="text-3xl font-black uppercase tracking-tighter mb-4">Our Mission</h2>
          <p class="font-medium text-gray-600 group-hover:text-black leading-relaxed">
            Zero-emission last-mile delivery that respects the consumer's time. We aim to eliminate the phrase "we missed you" from the English language.
          </p>
        </div>

        <div class="border-4 border-black p-12 bg-black text-white hover:bg-[#FFD600] hover:text-black transition-colors duration-500 group">
          <div class="w-16 h-16 bg-[#FFD600] text-black flex items-center justify-center font-black text-2xl mb-8 group-hover:bg-black group-hover:text-[#FFD600] transition-colors">
            V
          </div>
          <h2 class="text-3xl font-black uppercase tracking-tighter mb-4">Our Vision</h2>
          <p class="font-medium text-gray-400 group-hover:text-black leading-relaxed">
            To become the default logistics layer for premium D2C brands worldwide. If it matters, it ships Quickship Direct.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
