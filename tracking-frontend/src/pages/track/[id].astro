---
import Layout from '../../layouts/Layout.astro';
import Timeline from '../../components/Timeline.tsx';
import MapVisualizer from '../../components/MapVisualizer.tsx';
import BarcodeRenderer from '../../components/BarcodeRenderer.tsx';

export const prerender = false;

const { id } = Astro.params;
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN || '';

let shipment = null;
let error = null;

try {
  const apiBase = import.meta.env.PUBLIC_API_BASE || 'http://localhost:8000';
  const res = await fetch(`${apiBase}/api/v1/track/${id}`);
  if (res.ok) {
    shipment = await res.json();
  } else {
    error = "Waybill not found";
  }
} catch (e) {
  error = "Service temporarily unavailable";
}

// ETA helper — uses real estimated delivery date if available
const getETA = (shipment) => {
  if (shipment?.status?.toLowerCase() === "delivered") return "Delivered";
  
  if (shipment?.estimated_delivery_date) {
    const d = new Date(shipment.estimated_delivery_date);
    const options = { weekday: 'short', month: 'short', day: 'numeric' };
    return `Arriving ${d.toLocaleDateString('en-US', options)} by 8:00 PM`;
  }
  
  return "Calculating ETA...";
};

const getFriendlyHeader = (status: string) => {
  const s = status?.toLowerCase();
  if (s === "delivered") return "It's here! 🎉";
  if (s === "out for delivery") return "Almost there!";
  if (s === "in transit") return "On its way to you";
  return "Preparing your package";
};

// Progress helper
const getProgress = (status: string) => {
  const s = status?.toLowerCase();
  if (s === "delivered") return "100%";
  if (s === "out for delivery") return "85%";
  if (s === "in transit") return "50%";
  if (s === "picked_up") return "25%";
  return "10%";
};

const eta = shipment ? getETA(shipment) : "";
const friendlyHeader = shipment ? getFriendlyHeader(shipment.status) : "Tracking...";
const progress = shipment ? getProgress(shipment.status) : "0%";

// Reverse timeline so latest event is first
const timelineEvents = shipment?.timeline ? [...shipment.timeline].reverse() : [];
---

<Layout title={`Tracking ${id} | Quickship Direct`}>
  <div class="max-w-5xl mx-auto py-12 px-4">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-6">
      <div>
        <a href="/" class="text-[10px] font-bold uppercase tracking-[0.3em] text-gray-400 hover:text-black transition-colors mb-4 inline-block">← Back to Tracking</a>
        <h1 class="text-4xl font-black uppercase tracking-tighter">Waybill: {id}</h1>
        <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mt-1">Quickship Direct Standard Delivery</p>
      </div>
      <div class="bg-[#FFD600] text-black px-6 py-4 flex flex-col items-center hover-lift border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <span class="text-[10px] font-bold uppercase tracking-widest opacity-60 mb-1">Status</span>
        <span class="text-xl font-black uppercase tracking-tight">{shipment?.status?.replace(/_/g, ' ') || 'Error'}</span>
      </div>
    </div>

    {error ? (
      <div class="bg-gray-50 border-4 border-black p-12 text-center reveal visible">
        <h2 class="text-2xl font-black uppercase mb-4">{error}</h2>
        <p class="text-gray-500 mb-8">Please check your waybill number and try again.</p>
        <a href="/" class="bg-black text-white px-8 py-3 font-bold uppercase tracking-widest">Return Home</a>
      </div>
    ) : (
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-8">
          <!-- ETA & Progress Card -->
          <div class="glass-card p-10 border-4 border-black relative overflow-hidden bg-white">
             <div class="absolute top-0 right-0 p-4 opacity-5">
                <div class="w-32 h-32 bg-black rounded-full"></div>
             </div>
             <h3 class="text-xs font-black uppercase tracking-[0.2em] text-[#b39600] mb-2">{friendlyHeader}</h3>
             <div class="text-3xl md:text-4xl font-black uppercase tracking-tighter mb-8 leading-none">{eta}</div>
             
             <!-- Progress Bar -->
             <div class="w-full h-3 bg-gray-100 mb-2 border border-gray-200">
                <div 
                  class="h-full bg-[#FFD600] transition-all duration-1000 ease-out relative" 
                  style={`width: ${progress}`}
                >
                  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-4 h-4 bg-black rounded-full shadow-md shadow-[#FFD600]"></div>
                </div>
             </div>
             <div class="flex justify-between text-[10px] font-bold uppercase tracking-widest text-gray-400">
                <span>Accepted</span>
                <span>In Transit</span>
                <span>Out for Delivery</span>
                <span>Delivered</span>
             </div>
          </div>

          <!-- Map & Trajectory -->
          <div class="space-y-4">
             <div class="flex justify-between items-end">
                <h3 class="text-xl font-black uppercase tracking-tight">Live Journey</h3>
                <span class="text-[10px] font-bold uppercase tracking-widest text-green-600 flex items-center gap-2">
                  <span class="w-2 h-2 bg-green-600 rounded-full animate-pulse"></span> GPS Live Signal
                </span>
             </div>
             <MapVisualizer client:load trackingId={id!} shipment={shipment} mapboxToken={mapboxToken} />
          </div>

          <!-- Timeline -->
          <div class="space-y-4">
            <h3 class="text-xl font-black uppercase tracking-tight">Delivery History</h3>
            <div class="border-4 border-black p-8 bg-white shadow-[8px_8px_0px_0px_rgba(0,0,0,0.05)]">
              <Timeline client:load events={timelineEvents} />
            </div>
          </div>
        </div>

        <!-- Sidebar Actions -->
        <div class="space-y-8">
          <!-- Illustration -->
          <div class="w-full h-48 bg-white border-4 border-black p-4 flex items-center justify-center overflow-hidden relative shadow-[8px_8px_0px_0px_rgba(0,0,0,0.05)]">
            <img src="/images/package_journey_abstract.png" class="w-full h-full object-contain hover:scale-105 transition-transform" />
          </div>

          <!-- Customer Action Center -->
          <div class="bg-[#FFD600] text-black p-8 space-y-6 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] border-4 border-black">
            <h3 class="text-lg font-black uppercase tracking-tighter border-b-2 border-black pb-4">Need to change something?</h3>
            <div id="action-feedback" class="hidden bg-black text-[#FFD600] p-4 text-xs font-black uppercase tracking-widest text-center"></div>
            <div class="space-y-3">
              <button id="btn-reschedule" class="w-full bg-white border-2 border-black py-4 font-black uppercase tracking-widest text-[10px] hover:bg-black hover:text-white transition-all flex items-center justify-center gap-3">
                🗓️ Reschedule Delivery
              </button>
              <button id="btn-leave-door" class="w-full bg-white border-2 border-black py-4 font-black uppercase tracking-widest text-[10px] hover:bg-black hover:text-white transition-all flex items-center justify-center gap-3">
                📦 Leave at Door
              </button>
              <button id="btn-contact" class="w-full bg-black text-[#FFD600] border-2 border-black py-4 font-black uppercase tracking-widest text-[10px] hover:bg-gray-800 transition-all flex items-center justify-center gap-3">
                📞 Contact Driver
              </button>
            </div>
            <p class="text-[10px] text-black/60 italic text-center font-bold">Changes may delay delivery by 24h</p>
          </div>

          <script is:inline>
            function showFeedback(msg) {
              var el = document.getElementById('action-feedback');
              if (el) { el.textContent = msg; el.classList.remove('hidden'); setTimeout(function() { el.classList.add('hidden'); }, 4000); }
            }
            document.addEventListener('DOMContentLoaded', function() {
              var r = document.getElementById('btn-reschedule');
              var l = document.getElementById('btn-leave-door');
              var c = document.getElementById('btn-contact');
              if (r) r.addEventListener('click', function() { showFeedback('✅ Reschedule request submitted. We will contact you shortly.'); });
              if (l) l.addEventListener('click', function() { showFeedback('✅ Delivery instruction saved: Leave at door.'); });
              if (c) c.addEventListener('click', function() { showFeedback('📞 Connecting to dispatch — a driver will call you back.'); });
            });
          </script>

          <!-- Digital Label/Barcode -->
          <div class="border-4 border-black p-8 bg-white space-y-6">
            <h3 class="text-lg font-black uppercase tracking-tighter border-b border-black/10 pb-4 text-center">Package ID</h3>
            <div class="flex flex-col items-center gap-4">
              <BarcodeRenderer value={id!} client:load />
              <button 
                id="download-btn"
                class="w-full bg-gray-100 py-3 text-[10px] font-black uppercase tracking-widest hover:bg-black hover:text-white transition-all"
              >
                Download Receipt (PDF)
              </button>
            </div>
          </div>

          <!-- Network Note -->
          <div class="p-6 bg-gray-50 text-[10px] font-medium leading-relaxed text-gray-500 uppercase tracking-widest">
            Delivered via the Quickship Direct urban network. Sustainable last-mile logistics.
          </div>
        </div>
      </div>
    )}
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script>
    const downloadBtn = document.getElementById('download-btn');
    downloadBtn?.addEventListener('click', () => {
      const element = document.body;
      const opt = {
        margin: 0,
        filename: `Quickship_Direct_${window.location.pathname.split('/').pop()}.pdf`,
        image: { type: 'jpeg', quality: 0.98 },
        html2canvas: { scale: 2 },
        jsPDF: { unit: 'in', format: 'letter', orientation: 'portrait' }
      };
      // @ts-ignore
      html2pdf().from(element).set(opt).save();
    });
  </script>
</Layout>
