---
// Footer.astro
---
<footer class="bg-black text-white pt-24 pb-12 border-t-8 border-[#FFD600] relative overflow-hidden">
  <div class="absolute inset-0 opacity-10 mix-blend-screen pointer-events-none">
    <img src="/images/delivery_van_aerial.png" alt="" class="w-full h-full object-cover" />
  </div>
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="md:col-span-1">
        <div class="flex items-center gap-2 mb-6">
          <img src="/images/logo.png" alt="Quickship Direct Logo" class="w-10 h-10 object-contain" />
          <span class="text-xl font-black uppercase tracking-tighter text-white">Quickship <span class="font-light opacity-50">Direct</span></span>
        </div>
        <p class="text-xs text-gray-400 font-medium leading-relaxed mb-6">
          Premium D2C logistics with zero-emission last-mile delivery. We respect your time.
        </p>
      </div>
      
      <div>
        <h4 class="text-[10px] font-black uppercase tracking-widest text-[#FFD600] mb-6">Company</h4>
        <ul class="space-y-4 text-xs font-bold uppercase tracking-wider text-gray-400">
          <li><a href="/about" class="hover:text-white transition-colors flex items-center gap-2"><span class="w-1 h-1 bg-[#FFD600] rounded-full"></span> About Us</a></li>
          <li><a href="/about#mission" class="hover:text-white transition-colors flex items-center gap-2"><span class="w-1 h-1 bg-[#FFD600] rounded-full"></span> Mission & Vision</a></li>
          <li><a href="/reviews" class="hover:text-white transition-colors flex items-center gap-2"><span class="w-1 h-1 bg-[#FFD600] rounded-full"></span> Customer Reviews</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[10px] font-black uppercase tracking-widest text-[#FFD600] mb-6">Support</h4>
        <ul class="space-y-4 text-xs font-bold uppercase tracking-wider text-gray-400">
          <li><a href="/contact" class="hover:text-white transition-colors flex items-center gap-2"><span class="w-1 h-1 bg-[#FFD600] rounded-full"></span> Contact Us</a></li>
          <li><a href="/contact#faq" class="hover:text-white transition-colors flex items-center gap-2"><span class="w-1 h-1 bg-[#FFD600] rounded-full"></span> FAQ</a></li>
          <li><a href="/merchant" class="hover:text-white transition-colors flex items-center gap-2"><span class="w-1 h-1 bg-[#FFD600] rounded-full"></span> Merchant Portal</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-[10px] font-black uppercase tracking-widest text-[#FFD600] mb-6">Legal</h4>
        <ul class="space-y-4 text-xs font-bold uppercase tracking-wider text-gray-400">
          <li><a href="#" class="hover:text-white transition-colors flex items-center gap-2"><span class="w-1 h-1 bg-[#FFD600] rounded-full"></span> Privacy Policy</a></li>
          <li><a href="#" class="hover:text-white transition-colors flex items-center gap-2"><span class="w-1 h-1 bg-[#FFD600] rounded-full"></span> Terms of Service</a></li>
        </ul>
      </div>
    </div>
    
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-[10px] font-bold uppercase tracking-widest text-gray-500">
        &copy; 2026 Quickship Direct Inc. All rights reserved.
      </div>
      <div class="text-[10px] font-bold uppercase tracking-widest text-gray-500 flex gap-6">
        <span>Designed for the consumer</span>
        <span class="text-[#FFD600]">✦</span>
        <span>Built for scale</span>
      </div>
    </div>
  </div>
</footer>
