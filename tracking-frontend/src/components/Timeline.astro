---
interface TimelineEvent {
  status: string;
  location: string;
  timestamp: string;
  completed: boolean;
}

interface Props {
  events: TimelineEvent[];
}

const { events } = Astro.props;
---

<div class="border-l-4 border-black ml-4 pl-8 py-2 space-y-8 relative">
  {events.map((event, index) => (
    <div class="relative">
      <!-- Status dot -->
      <div class={`absolute -left-[42px] top-1 w-6 h-6 border-4 border-black bg-white rounded-full ${event.completed ? 'bg-black' : ''}`}></div>
      
      <div class={`${event.completed ? 'opacity-100' : 'opacity-40'}`}>
        <h3 class="text-xl font-black uppercase">{event.status}</h3>
        <p class="text-gray-600 font-medium mt-1">{event.location}</p>
        <time class="text-sm text-gray-500 font-bold block mt-1">{event.timestamp}</time>
      </div>
    </div>
  ))}
</div>
